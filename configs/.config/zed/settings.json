{
  "sticky_scroll": {
    "enabled": false,
  },
  "proxy": "",
  "project_panel": {
    "dock": "left",
  },
  "prettier": {
    "parser": "",
  },
  "which_key": {
    "enabled": true,
  },
  "cli_default_open_behavior": "new_window",
  "agent": {
    "tool_permissions": {
      "default": "confirm",
    },
    "default_profile": "ask",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4",
    },
  },
  "theme": {
    "mode": "system",
    "dark": "Catppuccin Frappé",
    "light": "Catppuccin Latte",
  },
  "show_whitespaces": "boundary",
  "ui_font_size": 15,
  "ui_font_family": "Iosevka Nerd Font",
  "buffer_font_size": 15,
  "buffer_font_family": "Iosevka Nerd Font",
  "terminal": {
    "font_family": "IosevkaTerm Nerd Font",
    "shell": {
      "program": "/opt/homebrew/bin/fish",
    },
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
  },
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "lsp": {
    "pyrefly": {
      "binary": {
        "path": ".venv/bin/pyrefly",
        "arguments": ["lsp"],
      },
      "settings": {
        "python": {
          "pythonPath": ".venv/bin/python",
        },
        "pyrefly": {
          "project_includes": ["src/**/*.py", "tests/**/*.py"],
          "project_excludes": ["**/.[!/.]*", "**/*venv/**"],
          "search_path": ["src"],
          "ignore_errors_in_generated_code": true,
        },
      },
    },
  },
  "languages": {
    "Plain Text": {
      "format_on_save": "off",
      "ensure_final_newline_on_save": false,
      "remove_trailing_whitespace_on_save": false,
      "prettier": {
        "allowed": false,
      },
    },
    "C": {
      "format_on_save": "on",
      "tab_size": 2,
    },
    "Python": {
      "format_on_save": "on",
      "language_servers": ["pyrefly", "ruff"],
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
      },
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
    },
    "SQL": {
      "formatter": {
        "external": {
          "command": "sql-formatter",
        },
      },
    },
  },
}
